# Coding Agent Configuration

# ===== API Credentials =====
# Your API key for the AI model endpoint
API_KEY=your-api-key-here

# The endpoint URL for the OpenAI-compatible API
# Examples:
#   - Anthropic API: https://api.anthropic.com/v1/messages
#   - OpenAI API: https://api.openai.com/v1/chat/completions
#   - Local provider: http://localhost:8000/v1/chat/completions
ENDPOINT_URL=https://api.example.com/v1/chat/completions

# ===== Optional Settings =====
# Uncomment and modify these if needed

# Default model name (used in API requests)
# MODEL=anthropic.claude-haiku-4-5-20251001

# Maximum tokens for API responses
# MAX_TOKENS=4096

# Temperature for summarization (0.0 = deterministic, 1.0 = creative)
# SUMMARY_TEMPERATURE=0.3

# ===== Provider-Specific Examples =====

# For Anthropic (Claude):
# API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# ENDPOINT_URL=https://api.anthropic.com/v1/messages

# For OpenAI (GPT-4):
# API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
# ENDPOINT_URL=https://api.openai.com/v1/chat/completions

# For Ollama (local):
# API_KEY=dummy-key
# ENDPOINT_URL=http://localhost:11434/v1/chat/completions
